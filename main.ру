# main.py — бот Mafia "The Don"
import random
from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, ContextTypes

# =============================
# Токен твого бота
TOKEN = "8758223475:AAERnFCq_nooCsSsMj1UcK_XwmYvuXEScLI"
# =============================

# Списки гравців і ролей
players = []
roles = {}
alive = []
game_started = False

# Команда /start — привітання
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🕵️‍♂️ Бот гри Мафія — The Don\n\n"
        "/join — приєднатись до гри\n"
        "/startgame — почати гру"
    )

# Команда /join — приєднатися до гри
async def join(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    if user.id not in players:
        players.append(user.id)
        await update.message.reply_text(f"{user.first_name} приєднався до гри!")
    else:
        await update.message.reply_text("Ти вже в грі.")

# Команда /startgame — почати гру
async def startgame(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global game_started, alive, roles
    if game_started:
        await update.message.reply_text("Гра вже йде!")
        return

    if len(players) < 4:
        await update.message.reply_text("Потрібно мінімум 4 гравці.")
        return

    game_started = True
    alive = players.copy()

    # Вибір мафії
    mafia = random.choice(players)
    for p in players:
        if p == mafia:
            roles[p] = "мафія"
            await context.bot.send_message(p, "🔪 Ти Мафія")
        else:
            roles[p] = "мирний"
            await context.bot.send_message(p, "👤 Ти Мирний житель")

    await update.message.reply_text("🌙 Ніч. Мафія обирає жертву.")

# =============================
# Підключення команд до бота
app = ApplicationBuilder().token(TOKEN).build()
app.add_handler(CommandHandler("start", start))
app.add_handler(CommandHandler("join", join))
app.add_handler(CommandHandler("startgame", startgame))

# Запуск бота
app.run_polling()
